  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/zerkerlabs/treeship",
    "directory": "packages/verify-js"
  },
  "homepage": "https://treeship.dev",
  "keywords": [
    "treeship",
    "verification",
    "verify",
    "attestation",
    "receipts",
    "certificate",
    "cross-verification",
    "wasm",
    "edge",
    "serverless"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
