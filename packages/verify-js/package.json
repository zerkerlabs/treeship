    "test": "vitest run"
  },
  "dependencies": {
    "@treeship/core-wasm": "0.9.9"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
