{
  "$comment": "SINGLE SOURCE OF TRUTH for Treeship product-surface design. Hand-edit this file only; tokens.rs / tokens.css / tokens.ts are code-generated from it (see design/README.md). Grounded in /DESIGN.md. Not the marketing site.",
  "meta": {
    "version": "1.0.0",
    "grounds": "DESIGN.md"
  },
  "color": {
    "paper":      { "value": "#F1F0EA", "role": "document ground" },
    "panel":      { "value": "#EBEAE1", "role": "inset panel / code chip ground" },
    "ink":        { "value": "#1F2329", "role": "primary text" },
    "muted":      { "value": "#5F646B", "role": "secondary text" },
    "faint":      { "value": "#9B9B93", "role": "tertiary / captions" },
    "hair":       { "value": "#DAD8CD", "role": "warm hairline rule" },
    "hair_cool":  { "value": "#CBCED0", "role": "cool hairline / registration ticks" },
    "steel":      { "value": "#37454F", "role": "cool accent: links, live elements" },
    "bronze":     { "value": "#856733", "role": "the one warm metallic: the seal" },
    "bronze_hi":  { "value": "#C6A972", "role": "seal ring highlight" },
    "bronze_lo":  { "value": "#5E4923", "role": "seal ring shadow" },
    "verdict_pass": { "value": "#3B6A4E", "role": "pass family" },
    "verdict_fail": { "value": "#9F4230", "role": "fail / revoked family" },
    "verdict_warn": { "value": "#8F5E1F", "role": "warn / declared family" }
  },
  "type": {
    "$comment": "Serif = human summary voice; sans = fields/labels; mono = cryptographic evidence ONLY. mono always tabular-nums.",
    "family": {
      "serif": "'Fraunces', Georgia, serif",
      "sans":  "'Switzer', 'Helvetica Neue', system-ui, sans-serif",
      "mono":  "'Berkeley Mono', 'JetBrains Mono', 'SF Mono', ui-monospace, monospace"
    },
    "scale": {
      "masthead":     { "px": 33, "family": "serif", "weight": 400, "tracking": "-0.02em" },
      "verdict":      { "px": 31, "family": "serif", "weight": 300, "tracking": "-0.02em" },
      "section_label":{ "px": 10, "family": "sans",  "weight": 600, "tracking": "0.22em", "transform": "uppercase" },
      "body":         { "px": 14.5, "family": "sans", "weight": 400, "tracking": "0" },
      "mono":         { "px": 11, "family": "mono",  "weight": 400, "tracking": "-0.02em" }
    },
    "root_features": ["tnum", "ss01"]
  },
  "space": {
    "$comment": "8px base. Generous between sections, tight within rows.",
    "unit": 8,
    "ladder": [4, 8, 12, 24, 48, 96]
  },
  "radius": {
    "sm": 5,
    "md": 12,
    "full": 9999
  },
  "motion": {
    "$comment": "One rationed beat on first paint; never animate uncertainty. Respect prefers-reduced-motion.",
    "rise": { "duration_ms": 700, "translate_px": 10, "easing": "cubic-bezier(.2,.7,.2,1)" },
    "seal_draw": { "duration_ms": 1100, "delay_ms": 250, "easing": "ease-out" }
  },
  "verdicts": {
    "$comment": "LOAD-BEARING. One canonical {word,color,glyph} per trust state, identical on every surface. Codegen emits this as an enum in each target. Do not add synonyms.",
    "full_pass":        { "word": "full pass",        "color": "verdict_pass", "glyph": "triangle" },
    "structural_pass":  { "word": "structural pass",  "color": "verdict_pass", "glyph": "triangle" },
    "countersigned":    { "word": "countersigned",    "color": "verdict_pass", "glyph": "triangle" },
    "permitted":        { "word": "permitted",        "color": "verdict_pass", "glyph": "circle" },
    "anchored":         { "word": "anchored",         "color": "verdict_pass", "glyph": "diamond" },
    "declared":         { "word": "declared",         "color": "verdict_warn", "glyph": "triangle_muted" },
    "self_asserted":    { "word": "self-asserted",    "color": "verdict_warn", "glyph": "triangle_muted" },
    "pending":          { "word": "pending",          "color": "muted",        "glyph": "dot" },
    "revoked":          { "word": "revoked",          "color": "verdict_fail", "glyph": "cross" },
    "unverified":       { "word": "unverified",       "color": "verdict_fail", "glyph": "cross" }
  },
  "glyphs": {
    "$comment": "The brand product marks, reused as trust glyphs. One meaning each, forever. Never invent a parallel set.",
    "triangle":       { "char": "△", "means": "treeship / identity" },
    "triangle_muted": { "char": "△", "means": "identity, low-certainty (rendered in warn color)" },
    "circle":         { "char": "○", "means": "gateway / capability" },
    "diamond":        { "char": "◇", "means": "memory / receipt" },
    "cross":          { "char": "✕", "means": "guard / revoked" },
    "check":          { "char": "✓", "means": "plain-verified" },
    "dot":            { "char": "·", "means": "pending" }
  }
}
