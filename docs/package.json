{
  "name": "treeship-docs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "sync:changelog": "node scripts/sync-changelog.mjs",
    "sync:agents-matrix": "node scripts/sync-agents-matrix.mjs",
    "sync:feature-matrix": "node scripts/sync-feature-matrix.mjs",
    "sync:all": "node scripts/sync-changelog.mjs && node scripts/sync-agents-matrix.mjs && node scripts/sync-feature-matrix.mjs",
    "predev": "npm run sync:all",
    "prebuild": "npm run sync:all",
    "dev": "next dev --port 3001",
    "build": "next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "fumadocs-core": "^15.8.5",
    "fumadocs-mdx": "^12.0.2",
    "fumadocs-ui": "^15.8.5",
    "fumadocs-openapi": "^5.0.0",
    "next": "^15.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^20",
    "yaml": "^2.9.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tailwindcss": "^4.0.0",
    "typescript": "^5"
  }
}
